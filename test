function startWebTools(){

    echo "=== WEB TOOLS ======="
    service apache2 start
    $PWPath/server pwAdmin start

}

function main(){

    echo "##############################   Server starting!  ######################################"
    trap 'echo "Script end!"' EXIT

    clearLog
    startAuthd
    startGamedbd
    startGacd
    startUniquenamed
    startGfactiond
    startLogservice
    loadMaps

    startGdeliveryd
    startGlinkd

    #startWebTools

}

main