function loadMaps(){

    echo "##############################  - Load Maps(GS) #########################################"
    # Map services #
    cd $PWPath/gamed/
    nohup ./gs gs01  >$LogsPath/gs01.log 2>&1 &
    sleep 2
    nohup ./gs is61  >$LogsPath/is61.log 2>&1 &
    sleep 1
    nohup ./gs is69  >$LogsPath/is69.log 2>&1 &

    GS=`ps -ef | grep gs | grep -v grep | awk '{print $2}'`
    if [ "$GS" != "" ]; then
       echo "The maps loaded successfully!"
    else
       echo "The maps loaded failed!"
    fi
    echo ""
}

